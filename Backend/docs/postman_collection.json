            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/chapters/course/<courseId>", "host": ["{{baseUrl}}"], "path": ["chapters", "course", "<courseId>"] }
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/chapters", "host": ["{{baseUrl}}"], "path": ["chapters"] },
            "body": { "mode": "raw", "raw": "{\n  \"courseId\": \"<courseId>\",\n  \"title\": \"Getting Started\",\n  \"order\": 1\n}" }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PATCH",
