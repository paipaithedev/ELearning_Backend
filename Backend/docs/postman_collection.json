              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/chapters/<chapterId>", "host": ["{{baseUrl}}"], "path": ["chapters", "<chapterId>"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Title\",\n  \"order\": 2\n}" }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/chapters/<chapterId>", "host": ["{{baseUrl}}"], "path": ["chapters", "<chapterId>"] }
          }
        }
      ]
    },
